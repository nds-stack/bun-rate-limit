{
  "name": "@nds-stack/bun-rate-limit", "version": "0.1.0-alpha.0",
  "description": "Token bucket rate limiter for Bun — in-memory, zero dependencies",
  "author": "nds-stack <nds.stack@gmail.com>", "type": "module",
  "main": "dist/index.js", "types": "dist/index.d.ts",
  "exports": { ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" } },
  "scripts": {
    "test": "bun test", "lint": "eslint .", "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "bench": "bun run bench/rate-limit.bench.ts",
    "prepublishOnly": "bun run lint && bun run typecheck && bun test && bun run build",
    "build": "bun build ./src/index.ts --outdir=./dist --target=bun --format=esm && tsc -p tsconfig.build.json"
  },
  "files": ["dist/", "README.md"],
  "repository": { "type": "git", "url": "git+https://github.com/nds-stack/bun-rate-limit.git" },
  "publishConfig": { "access": "public" },
  "devDependencies": { "@eslint/js": "^10.0.1", "@types/bun": "latest", "eslint": "^10.3.0", "typescript-eslint": "^8.59.2" },
  "engines": { "bun": ">=1.3.0" },
  "keywords": ["bun", "rate-limit", "token-bucket", "throttle"], "license": "MIT"
}
